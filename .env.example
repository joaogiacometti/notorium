# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=notorium
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://postgres:change-this-password@localhost:5432/notorium

# Application
APP_PORT=3000
NODE_ENV=development

# Redis (for rate limiting)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Authentication
BETTER_AUTH_SECRET=replace-with-a-random-64-char-secret
BETTER_AUTH_URL=http://localhost:3000

# Rate Limiting (choose one)
RATE_LIMIT_BACKEND=redis
# UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI Settings Encryption (BYOK)
# Generate with: openssl rand -base64 32
USER_AI_SETTINGS_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key

# Testing
E2E_USER_PASSWORD=replace-with-a-strong-random-password
