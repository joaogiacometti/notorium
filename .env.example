# App runtime
DATABASE_URL=postgresql://postgres:change-this-password@localhost:5432/notorium
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-random-64-char-secret
NODE_ENV=development

# Rate limiting
RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional features
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=Notorium <notifications@your-verified-domain.com>
# CRON_SECRET=replace-with-a-random-64-char-secret

# Docker Compose helpers
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=notorium
POSTGRES_PORT=5432
REDIS_PORT=6379
APP_PORT=3000
