POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=notorium
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
APP_PORT=3000
REDIS_PORT=6379

DATABASE_URL=postgresql://postgres:change-this-password@localhost:5432/notorium

BETTER_AUTH_SECRET=replace-with-a-random-64-char-secret
BETTER_AUTH_URL=http://localhost:3000
RATE_LIMIT_BACKEND=redis
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REDIS_URL=redis://localhost:6379
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_PREFIX=ratelimit:auth
MAX_IMPORT_BYTES=1048576
TRUSTED_PROXY_COUNT=1

E2E_USER_NAME=Notorium E2E User
E2E_USER_EMAIL=e2e-user@notorium.local
E2E_USER_PASSWORD=notorium-e2e-password
E2E_STORAGE_STATE_PATH=e2e/.auth/user.json
