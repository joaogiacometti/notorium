# Test PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=notorium_test
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/notorium_test

# Test Redis
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# Test Application
BETTER_AUTH_URL=http://127.0.0.1:3001
BETTER_AUTH_SECRET=replace-with-a-random-64-char-secret-for-testing

# Rate Limiting
RATE_LIMIT_BACKEND=redis

# AI Settings Encryption (BYOK)
USER_AI_SETTINGS_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key

# Playwright
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001