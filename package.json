{
  "name": "notorium",
  "version": "0.1.0",
  "description": "A study management app for students with subjects, notes, flashcards, attendance, and assessments",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:infra:up": "docker compose -f compose.test.yml --env-file .env.test up -d",
    "test:e2e:infra:down": "docker compose -f compose.test.yml --env-file .env.test down -v",
    "test:e2e:migrate": "bun --env-file=.env.test run db:migrate",
    "test:e2e": "bun --env-file=.env.test run playwright test",
    "test:e2e:ui": "bun --env-file=.env.test run playwright test --ui",
    "test:e2e:headed": "bun --env-file=.env.test run playwright test --headed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@napi-rs/wasm-runtime": "^1.1.1",
    "@open-spaced-repetition/binding": "^0.1.2",
    "@openrouter/ai-sdk-provider": "^2.2.5",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-code-block-lowlight": "^3.20.0",
    "@tiptap/extension-highlight": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-task-item": "^3.20.0",
    "@tiptap/extension-task-list": "^3.20.0",
    "@tiptap/extension-typography": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.116",
    "better-auth": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "pg": "^8.19.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "redis": "^5.11.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ts-fsrs": "^5.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@biomejs/biome": "2.4.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.9",
    "happy-dom": "^20.7.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joaogiacometti/notorium.git"
  },
  "keywords": [
    "study",
    "education",
    "flashcards",
    "notes",
    "spaced-repetition"
  ],
  "author": "João Pedro Giacometti Guerreiro <j.guerreiro@unesp.br>",
  "bugs": {
    "url": "https://github.com/joaogiacometti/notorium/issues"
  },
  "homepage": "https://github.com/joaogiacometti/notorium#readme"
}
